{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SH-Jarvis",
  "version": "0.1.0",
  "identifier": "de.shjarvis.client",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SH-Jarvis · Client",
        "width": 780,
        "height": 640,
        "resizable": true,
        "visible": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["sidecar-bin/jarvis-client"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
