# ── SH-Mark-XL GPU-Server — Konfiguration ──────────────────────────────
# Kopieren nach ".env" und anpassen:   cp .env.example .env

# An welche Host-Adresse die Dienste gebunden werden.
#   0.0.0.0      = alle Interfaces (LAN/VPN — Standard)
#   10.x.x.x     = nur eine bestimmte (z.B. WireGuard-)Adresse  ← sicherer
BIND_ADDR=0.0.0.0

# LLM: läuft hier extern via llama.cpp auf :8080 (OpenAI-kompatibel, /v1).
# Die folgenden zwei Variablen gelten NUR, falls du stattdessen den optionalen
# Ollama-Dienst nutzt (--profile ollama):
LLM_MODEL=qwen2.5:7b
VISION_MODEL=qwen2.5vl:7b

# STT-Modell (CTranslate2-HF-Repo, deutsch):
STT_MODEL=jimmymeister/whisper-large-v3-turbo-german-ct2

# TTS-Standardstimme: dm_martin (M) | df_victoria (F) | df_eva (F)
TTS_VOICE=dm_martin

# TTS-Host-Port (8080 ist von llama.cpp belegt → 8002):
TTS_PORT=8002
